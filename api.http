### ─────────────────────────────────────────
### HEALTH CHECK
### ─────────────────────────────────────────

GET {{baseUrl}}/health

### ─────────────────────────────────────────
### AUTH
### ─────────────────────────────────────────

### Sign up
POST {{baseUrl}}/auth/sign-up
Content-Type: application/json

{
  "email": "{{authEmail}}",
  "password": "{{authPassword}}",
  "full_name": "Farm Owner"
}

###

### Sign in
POST {{baseUrl}}/auth/sign-in
Content-Type: application/json

{
  "email": "{{authEmail}}",
  "password": "{{authPassword}}"
}

###

### Refresh session
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

###

### Get current user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

### ─────────────────────────────────────────
### PROTECTED ROUTES (Bearer token required)
### ─────────────────────────────────────────

### ─────────────────────────────────────────
### COWS
### ─────────────────────────────────────────

### Create cow
POST {{baseUrl}}/cows
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "tag_number": "COW-001",
  "breed": "Friesian",
  "date_of_birth": "2020-03-15",
  "source": "bought"
}

###

### List all cows
GET {{baseUrl}}/cows
Authorization: Bearer {{accessToken}}

###

### List active cows
GET {{baseUrl}}/cows?status=active
Authorization: Bearer {{accessToken}}

###

### Get single cow
GET {{baseUrl}}/cows/{{cowId}}
Authorization: Bearer {{accessToken}}

###

### Update cow status (soft delete / mark sold)
PATCH {{baseUrl}}/cows/{{cowId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": "sold"
}

### ─────────────────────────────────────────
### HEALTH RECORDS
### ─────────────────────────────────────────

### Create health record (treatment)
POST {{baseUrl}}/cows/{{cowId}}/health-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "type": "treatment",
  "description": "Mastitis treatment",
  "drug_used": "Penicillin",
  "next_due_date": "2026-04-11",
  "record_date": "2026-04-04",
  "notes": "Left rear quarter affected"
}

###

### Create health record (vaccination)
POST {{baseUrl}}/cows/{{cowId}}/health-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "type": "vaccination",
  "description": "FMD vaccine",
  "next_due_date": "2026-10-04"
}

###

### Create health record (deworming)
POST {{baseUrl}}/cows/{{cowId}}/health-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "type": "deworming",
  "description": "Routine deworming",
  "drug_used": "Albendazole",
  "next_due_date": "2026-07-04"
}

###

### List health records for a cow
GET {{baseUrl}}/cows/{{cowId}}/health-records
Authorization: Bearer {{accessToken}}

###

### Get single health record
GET {{baseUrl}}/cows/{{cowId}}/health-records/{{healthRecordId}}
Authorization: Bearer {{accessToken}}

###

### Update health record
PATCH {{baseUrl}}/cows/{{cowId}}/health-records/{{healthRecordId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "next_due_date": "2026-04-18",
  "notes": "Responding well to treatment"
}

### ─────────────────────────────────────────
### BREEDING RECORDS
### ─────────────────────────────────────────

### Log heat
POST {{baseUrl}}/cows/{{cowId}}/breeding-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "event_type": "heat",
  "event_date": "2026-04-04",
  "notes": "Strong signs observed"
}

###

### Log service (AI / bull)
POST {{baseUrl}}/cows/{{cowId}}/breeding-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "event_type": "service",
  "event_date": "2026-04-05",
  "expected_calving_date": "2027-01-10",
  "notes": "AI — Friesian semen"
}

###

### Log pregnancy check
POST {{baseUrl}}/cows/{{cowId}}/breeding-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "event_type": "pregnancy_check",
  "event_date": "2026-05-05",
  "expected_calving_date": "2027-01-10",
  "notes": "Confirmed pregnant — 30 days"
}

###

### Log calving (creates calf automatically)
POST {{baseUrl}}/cows/{{cowId}}/breeding-records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "event_type": "calving",
  "event_date": "2027-01-10",
  "notes": "Normal delivery",
  "calf": {
    "tag_number": "CALF-001",
    "breed": "Friesian",
    "date_of_birth": "2027-01-10"
  }
}

###

### List breeding records for a cow
GET {{baseUrl}}/cows/{{cowId}}/breeding-records
Authorization: Bearer {{accessToken}}

###

### Get single breeding record
GET {{baseUrl}}/cows/{{cowId}}/breeding-records/{{breedingRecordId}}
Authorization: Bearer {{accessToken}}

### ─────────────────────────────────────────
### MILK LOGS
### ─────────────────────────────────────────

### Log today's milk
POST {{baseUrl}}/cows/{{cowId}}/milk-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "litres": 8.5,
  "period": "morning",
  "notes": "Normal"
}

###

### Log milk for a specific date
POST {{baseUrl}}/cows/{{cowId}}/milk-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "litres": 7.0,
  "period": "evening",
  "log_date": "2026-04-03"
}

###

### List milk logs for a cow
GET {{baseUrl}}/cows/{{cowId}}/milk-logs
Authorization: Bearer {{accessToken}}

###

### Update milk log
PATCH {{baseUrl}}/cows/{{cowId}}/milk-logs/{{milkLogId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "litres": 6.5,
  "notes": "Corrected evening reading"
}

