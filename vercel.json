{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/vercel.ts"
    }
  ],
  "crons": [
    {
      "path": "/v1/notifications/daily-alerts",
      "schedule": "0 15 * * *"
    }
  ]
}
